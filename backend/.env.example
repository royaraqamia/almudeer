# ===========================================
# Al-Mudeer Backend - Environment Configuration
# ===========================================
# SECURITY WARNING: Never commit actual .env file to version control!
# Copy this file to .env and fill in your actual values.
# Generate new secrets for all fields marked [GENERATE NEW]

# -------------------------------------------
# Admin & Authentication
# -------------------------------------------
# [GENERATE NEW] 64 hex characters = 256 bits of entropy
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_KEY=[GENERATE NEW - 64 hex chars]

# [GENERATE NEW] 64 hex characters = 256 bits of entropy
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=[GENERATE NEW - 64 hex chars]

# [GENERATE NEW] 64 hex characters = 256 bits of entropy
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DEVICE_SECRET_PEPPER=[GENERATE NEW - 64 hex chars]
# IMPORTANT: Store this securely. Changing it will invalidate all existing device sessions.

# [GENERATE NEW] 64 hex characters = 256 bits of entropy
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# SECURITY FIX #6: Server-side pepper for license key hashing (prevents rainbow table attacks)
LICENSE_KEY_PEPPER=[GENERATE NEW - 64 hex chars]
# IMPORTANT: Store this securely. Changing it will require re-hashing all license keys.
# For development, a fixed pepper is used if not set. NEVER use development peppers in production.

# Optional: Dedicated OTP HMAC pepper (falls back to LICENSE_KEY_PEPPER if not set)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
OTP_HMAC_PEPPER=[GENERATE NEW - 64 hex chars]

# Encryption key for sensitive data (Fernet key format)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=[GENERATE NEW - Fernet key]

# Optional salt for key derivation (64 hex chars recommended)
ENCRYPTION_SALT=

# JWT Token Expiration
# Access tokens: short-lived (30 min default, industry standard)
JWT_ACCESS_EXPIRE_MINUTES=30
# Refresh tokens: longer-lived (7 days)
JWT_REFRESH_EXPIRE_DAYS=7
# Offline grace period: expired access tokens still work within this window
# Allows offline-first UX — client refreshes in background
JWT_OFFLINE_GRACE_MINUTES=60

# Device Secret Configuration
# Grace period days for legacy sessions to upgrade to device-bound sessions
# Set to 0 for immediate enforcement (recommended for production)
DEVICE_SECRET_GRACE_PERIOD_DAYS=0

# -------------------------------------------
# Database Configuration
# -------------------------------------------
DB_TYPE=postgresql
DATABASE_PATH=almudeer.db

# [SECURITY] Use environment-specific database credentials
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:[PASSWORD]@localhost:5432/almudeer

# Query timeout in seconds
DB_QUERY_TIMEOUT=30

# -------------------------------------------
# Redis Configuration (REQUIRED FOR PRODUCTION)
# -------------------------------------------
# Format: redis://[:password]@host:port
# [SECURITY] Use strong password and restrict network access
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# Google Cloud Platform
# -------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=firebase-service-account.json

# -------------------------------------------
# Firebase Cloud Messaging (FCM)
# -------------------------------------------
FCM_PROJECT_ID=your-fcm-project-id

# [SECURITY] Keep FCM server key secret - allows sending push notifications
FCM_SERVER_KEY=[YOUR FCM SERVER KEY]

# -------------------------------------------
# VAPID Keys for Web Push Notifications
# -------------------------------------------
# Generate with: web-push generate-vapid-keys
VAPID_PUBLIC_KEY=[YOUR VAPID PUBLIC KEY]
VAPID_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n[YOUR VAPID PRIVATE KEY]\n-----END PRIVATE KEY-----\n
VAPID_CLAIMS_ID=mailto:admin@royaraqamia.com

# -------------------------------------------
# Frontend & HTTPS
# -------------------------------------------
FRONTEND_URL=https://your-domain.com
HTTPS_ONLY=true

# Allow all localhost ports for Flutter web development
# Default: true (allows any localhost port for local development)
# Set to 'false' in production to restrict to only FRONTEND_URL
ALLOW_ALL_LOCALHOST=true

# -------------------------------------------
# Auto Update Configuration
# -------------------------------------------
MAX_APK_SIZE_MB=150
# Primary APK download URL (Cloudflare R2 or CDN)
APK_DOWNLOAD_URL=https://almudeercdn.royaraqamia.com/almudeer.apk
# Legacy CDN URLs (kept for backward compatibility)
APK_CDN_URL=https://your-domain.com/apk
APK_CDN_URL_UNIVERSAL=https://your-cdn.com/almudeer.apk
APK_CDN_URL_ARM64=https://your-cdn.com/almudeer_arm64_v8a.apk
APK_CDN_URL_ARMV7=https://your-cdn.com/almudeer_armeabi_v7a.apk
APK_CDN_URL_X86=https://your-cdn.com/almudeer_x86_64.apk
APP_DOWNLOAD_URL=https://your-domain.com/download/almudeer.apk
FORCE_UPDATE_ENABLED=true

# Rate limiting for version check
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# -------------------------------------------
# Admin Security
# -------------------------------------------
# Comma-separated list of allowed admin IPs (leave empty to allow all)
ADMIN_IP_WHITELIST=

# -------------------------------------------
# Environment
# -------------------------------------------
# Set to 'production' in production environment
ENVIRONMENT=development

# -------------------------------------------
# Email / SMTP Configuration
# -------------------------------------------
# Free SMTP service recommendations:
# 1. Brevo (Sendinblue): 300 emails/day free, no credit card needed
# 2. Resend: 3,000 emails/month, 100/day free, developer-friendly
# 3. SMTP2GO: 1,000 emails/month free
# 4. Mailgun: 5,000/month free (first 3 months)
# 5. SendGrid: 100/day free forever
#
# RECOMMENDED: Brevo or Resend (best free tiers for Arab markets)

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true
FROM_EMAIL=noreply@almudeer.com
FROM_NAME=Al-Mudeer | المدير
APP_BASE_URL=https://almudeer.up.railway.app
OTP_EXPIRY_MINUTES=10
OTP_COOLDOWN_SECONDS=60
RESET_TOKEN_EXPIRY_HOURS=1
