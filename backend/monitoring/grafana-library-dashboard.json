{
  "dashboard": {
    "id": null,
    "uid": "library-monitoring",
    "title": "Al-Mudeer Library Monitoring",
    "tags": ["library", "almudeer"],
    "timezone": "UTC",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "type": "timeseries",
        "title": "Library Uploads & Downloads",
        "targets": [
          {
            "expr": "rate(library_uploads_total[5m])",
            "legendFormat": "Uploads/s - {{license_id}} - {{item_type}}",
            "refId": "A"
          },
          {
            "expr": "rate(library_downloads_total[5m])",
            "legendFormat": "Downloads/s - {{license_id}} - {{item_type}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {"drawStyle": "line"}
          }
        }
      },
      {
        "id": 2,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "type": "timeseries",
        "title": "Storage Usage by License",
        "targets": [
          {
            "expr": "library_storage_usage_bytes",
            "legendFormat": "License {{license_id}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {"drawStyle": "line"}
          }
        }
      },
      {
        "id": 3,
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
        "type": "gauge",
        "title": "Storage Quota Warning Level",
        "targets": [
          {
            "expr": "library_quota_warning",
            "legendFormat": "License {{license_id}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 3,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "orange", "value": 2},
                {"color": "red", "value": 3}
              ]
            },
            "mappings": [
              {"type": "value", "options": {"0": {"text": "Normal"}}},
              {"type": "value", "options": {"1": {"text": "80%"}}},
              {"type": "value", "options": {"2": {"text": "90%"}}},
              {"type": "value", "options": {"3": {"text": "95%"}}}
            ]
          }
        }
      },
      {
        "id": 4,
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
        "type": "stat",
        "title": "Total Library Items",
        "targets": [
          {
            "expr": "sum(library_items_total)",
            "legendFormat": "Total Items",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "short"}
        }
      },
      {
        "id": 5,
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
        "type": "stat",
        "title": "Total Upload Errors (24h)",
        "targets": [
          {
            "expr": "increase(library_errors_total{operation=\"upload\"}[24h])",
            "legendFormat": "Upload Errors",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
        "type": "stat",
        "title": "Share Operations (24h)",
        "targets": [
          {
            "expr": "increase(library_shares_total[24h])",
            "legendFormat": "{{action}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {"defaults": {"unit": "short"}}
      },
      {
        "id": 7,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "type": "timeseries",
        "title": "Operation Latency (p50, p95, p99)",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(library_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(library_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(library_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {"drawStyle": "line"}
          }
        }
      },
      {
        "id": 8,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "type": "timeseries",
        "title": "Upload Duration by Type",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(library_upload_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 - {{item_type}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {"drawStyle": "line"}
          }
        }
      },
      {
        "id": 9,
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 20},
        "type": "table",
        "title": "Storage Usage by License",
        "targets": [
          {
            "expr": "library_storage_usage_bytes",
            "legendFormat": "License {{license_id}}",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "Value #A": false},
              "renameByName": {"Value #A": "Bytes", "license_id": "License ID"}
            }
          }
        ]
      }
    ],
    "templating": {
      "list": [
        {
          "name": "license_id",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(library_storage_usage_bytes, license_id)",
          "refresh": 1,
          "multi": true,
          "includeAll": true
        }
      ]
    },
    "time": {"from": "now-6h", "to": "now"},
    "timepicker": {}
  }
}
