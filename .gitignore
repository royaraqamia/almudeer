# Root .gitignore for Almudeer Monorepo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Root IDE folders (subfolders have their own)
/.idea/
/.vscode/

# Mobile app build artifacts
mobile-app/android/app/build/
mobile-app/android/.gradle/
mobile-app/android/build/
mobile-app/android/.flutter-plugins-dependencies
mobile-app/android/.flutter-plugins
mobile-app/android/local.properties
mobile-app/android/app/google-services.json
mobile-app/android/app/debug/
mobile-app/android/app/release/
mobile-app/android/app/profile/
mobile-app/android/gradlew
mobile-app/android/gradlew.bat
mobile-app/android/keystores/

# Flutter build outputs
mobile-app/build/
mobile-app/.dart_tool/
mobile-app/.flutter-plugins-dependencies
mobile-app/.flutter-plugins
mobile-app/pubspec.lock

# iOS build artifacts
mobile-app/ios/build/
mobile-app/ios/Pods/
mobile-app/ios/.symlinks/
mobile-app/ios/Podfile.lock

# Web build
mobile-app/build/

# Debug files
*.log
*.tmp
*.temp
