# Root .gitignore for Almudeer Monorepo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Root IDE folders (subfolders have their own)
/.idea/
/.vscode/

# Mobile app build artifacts
mobile_app/android/app/build/
mobile_app/android/.gradle/
mobile_app/android/build/
mobile_app/android/.flutter-plugins-dependencies
mobile_app/android/.flutter-plugins
mobile_app/android/local.properties
mobile_app/android/app/google-services.json
mobile_app/android/app/debug/
mobile_app/android/app/release/
mobile_app/android/app/profile/
mobile_app/android/gradlew
mobile_app/android/gradlew.bat
mobile_app/android/keystores/

# Flutter build outputs
mobile_app/build/
mobile_app/.dart_tool/
mobile_app/.flutter-plugins-dependencies
mobile_app/.flutter-plugins
mobile_app/pubspec.lock

# iOS build artifacts
mobile_app/ios/build/
mobile_app/ios/Pods/
mobile_app/ios/.symlinks/
mobile_app/ios/Podfile.lock

# Web build
mobile-app/build/

# Debug files
*.log
*.tmp
*.temp

# Test databases
test_*.db
*_test.db
test_*.sqlite
*_test.sqlite
