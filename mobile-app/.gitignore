**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Build logs and artifacts
build_*.txt
build_error_full.txt
build_final_log.txt
build_log.txt
build_output.txt
build_result*.txt
build_stacktrace.txt
*.hprof

# Gradle local repo
/android/local-repo/

# Cache files
*.hive
*.lock

# Debug/temp files
fix_api_client.py
dialog_results.txt
search_results.txt

# Google/Firebase secrets (NEVER commit these)
**/google-services.json
**/GoogleService-Info.plist

# Android signing keys (NEVER commit these - security critical)
*.jks
*.keystore
**/*.jks
**/*.keystore
key.properties
**/key.properties
KEYSTORE_CREDENTIALS_README.txt
**/KEYSTORE_CREDENTIALS_README.txt

# Keystore backups (NEVER commit these)
*keystore-backup*.zip
**/*keystore-backup*.zip

# ProGuard/R8 mapping files (generated, keep in secure backup)
**/mapping.txt
**/seeds.txt
**/usage.txt
**/build/outputs/symbols/
mapping-backups/
