<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Browser app: Allow cleartext traffic for WebView -->
    <!-- This is required for a browser to load HTTP websites -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
